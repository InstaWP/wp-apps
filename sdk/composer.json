{
    "name": "instawp/wp-apps-sdk-php",
    "description": "WP Apps SDK — build sandboxed WordPress apps in PHP",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "InstaWP",
            "homepage": "https://instawp.com"
        }
    ],
    "require": {
        "php": ">=8.1"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0"
    },
    "autoload": {
        "psr-4": {
            "WPApps\\SDK\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "WPApps\\SDK\\Tests\\": "tests/"
        }
    },
    "config": {
        "sort-packages": true
    }
}
