{
    "$schema": "https://wp-apps.org/schema/v1/manifest.json",
    "spec_version": "0.1.0",

    "app": {
        "id": "com.example.hello-app",
        "name": "Hello App",
        "version": "1.0.0",
        "description": "A minimal example WP App that adds a greeting to post content.",
        "author": {
            "name": "WP Apps Team",
            "url": "https://wp-apps.org"
        },
        "license": "MIT"
    },

    "runtime": {
        "endpoint": "http://localhost:8888",
        "health_check": "/health",
        "auth_callback": "/auth/callback",
        "webhook_path": "/hooks",
        "timeout_ms": 5000
    },

    "requires": {
        "wp_version": ">=6.5",
        "php_version": ">=8.1",
        "apps_runtime_version": ">=0.1.0"
    },

    "permissions": {
        "scopes": [
            "posts:read",
            "posts:write",
            "postmeta:read",
            "postmeta:write"
        ]
    },

    "hooks": {
        "filters": [
            {
                "hook": "the_content",
                "priority": 99,
                "timeout_ms": 1000,
                "description": "Append a greeting banner to post content"
            }
        ],
        "actions": [
            {
                "hook": "save_post",
                "priority": 10,
                "timeout_ms": 3000,
                "async": true,
                "description": "Log word count on post save"
            }
        ]
    }
}
