{
    "name": "instawp/wp-apps-runtime",
    "description": "WordPress Apps Runtime — mu-plugin that manages sandboxed app extensions",
    "type": "wordpress-muplugin",
    "license": "GPL-2.0-or-later",
    "authors": [
        {
            "name": "InstaWP",
            "homepage": "https://instawp.com"
        }
    ],
    "require": {
        "php": ">=8.1"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0",
        "yoast/phpunit-polyfills": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "WPApps\\Runtime\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "WPApps\\Runtime\\Tests\\": "tests/"
        }
    },
    "config": {
        "sort-packages": true,
        "platform-check": false
    }
}
